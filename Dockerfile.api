# ── Dockerfile.api ─────────────────────────────────────────────────────────
FROM python:3.11-slim AS api
WORKDIR /code
COPY requirements.api.txt .
RUN pip install --no-cache-dir -r requirements.api.txt
COPY app/ ./app/
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "4"]
